# ─────────────────────────────────────────────────────────────────────────────
# Core — required on every environment
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/artixhub
JWT_SECRET=change-me-to-a-long-random-string

# ─────────────────────────────────────────────────────────────────────────────
# URLs — must match the actual origin for CORS and redirects
# ─────────────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000

# ─────────────────────────────────────────────────────────────────────────────
# OAuth providers — create apps at console.google.com / github.com/settings/apps
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Stripe — find keys at dashboard.stripe.com/apikeys
# Webhook secret: dashboard.stripe.com/webhooks (use stripe CLI for local dev)
# Price IDs: dashboard.stripe.com/products
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STUDENT=price_...
STRIPE_PRICE_RESEARCHER=price_...
STRIPE_PRICE_VISIONARY=price_...
STRIPE_PRICE_TEAM=price_...

# ─────────────────────────────────────────────────────────────────────────────
# MercadoPago — find credentials at mercadopago.com/developers/panel
# Plan IDs are preapproval_plan IDs created via the MP API
# ─────────────────────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-...
MP_WEBHOOK_SECRET=
MP_PLAN_STUDENT=
MP_PLAN_VISIONARY=

# ─────────────────────────────────────────────────────────────────────────────
# Email — choose ONE provider and fill in the matching block
# ─────────────────────────────────────────────────────────────────────────────
EMAIL_FROM=noreply@artixhub.com

# Option A — SendGrid (recommended for production)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG....

# Option B — Generic SMTP (works with Gmail, Mailgun SMTP, etc.)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
