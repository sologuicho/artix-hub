generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                 @id @default(cuid())
  provider               String
  providerId             String?
  email                  String?                @unique
  username               String?                @unique
  password               String?
  name                   String?
  avatar                 String?
  bio                    String?
  role                   Role                   @default(USER)
  country                String?
  occupation             String?
  interests              String[]
  profileComplete        Boolean                @default(false)
  banned                 Boolean                @default(false)
  tokenVersion           Int                    @default(0)
  articles               Article[]              @relation("ArticleAuthor")
  research               Research[]             @relation("ResearchAuthor")
  events                 Event[]                @relation("EventCreator")
  blogPosts              BlogPost[]             @relation("BlogPostAuthor")
  discussions            Discussion[]           @relation("DiscussionAuthor")
  comments               Comment[]              @relation("CommentAuthor")
  eventRegistrations     EventRegistration[]
  reactions              Reaction[]
  eventReminders         EventReminder[]
  notifications          Notification[]
  articleCollaborations  ArticleCollaborator[]
  researchCollaborations ResearchCollaborator[]
  eventCollaborations    EventCollaborator[]
  savedItems             SavedItem[]
  following              Follow[]               @relation("UserFollowing")
  followers              Follow[]               @relation("UserFollowers")
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  readingProgress        ReadingProgress[]
  reposts                Repost[]

  emailVerified          Boolean                @default(false)
  subscriptionTier       SubscriptionTier       @default(OBSERVER)
  stripeCustomerId       String?                @unique
  stripeSubscriptionId   String?                @unique
  dailyUsage             DailyUsage[]
  passwordResetTokens    PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  studentVerification    StudentVerification?

  @@index([username])
  @@index([email])
}

model StudentVerification {
  id          String                      @id @default(cuid())
  userId      String                      @unique
  user        User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  email       String?
  documentUrl String?                     @db.Text
  status      StudentVerificationStatus   @default(PENDING)
  reviewNote  String?
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt

  @@index([status])
}

enum StudentVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionTier {
  OBSERVER
  STUDENT
  RESEARCHER
  TEAM
  VISIONARY
}

model DailyUsage {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime @db.Date // Store only date component if possible, or midnight UTC
  articlesRead Int      @default(0)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
}

model ReadingProgress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  articleId String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  researchId String?
  research   Research? @relation(fields: [researchId], references: [id], onDelete: Cascade)
  
  postId    String?
  post      BlogPost? @relation(fields: [postId], references: [id], onDelete: Cascade)

  percentage    Float    @default(0) // 0 to 100
  lastPage      Int      @default(1)
  totalPages    Int      @default(1)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, articleId])
  @@unique([userId, researchId])
  @@unique([userId, postId])
  
  @@index([userId])
  @@index([updatedAt])
}

model SavedItem {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleId  String?
  article    Article?  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  researchId String?
  research   Research? @relation(fields: [researchId], references: [id], onDelete: Cascade)
  postId     String?
  post       BlogPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  eventId    String?
  event      Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@unique([userId, articleId])
  @@unique([userId, researchId])
  @@unique([userId, postId])
  @@unique([userId, eventId])
  @@index([userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Article {
  id              String                @id @default(cuid())
  title           String
  content         String                @db.Text
  description     String?
  category        String
  tags            String[]
  status          String                @default("draft") // draft, reviewing, published, archived
  coverUrl        String?
  pdfUrl          String?
  references      String[]
  isCollaborative Boolean               @default(false)
  authorId        String
  author          User                  @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  collaborators   ArticleCollaborator[]
  comments        Comment[]
  reactions       Reaction[]
  savedItems      SavedItem[]
  readingProgress ReadingProgress[]
  reposts         Repost[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([authorId])
  @@index([category])
  @@index([status])
  @@index([title])
}

// Research/Investigaciones Model - Research generates Articles
model Research {
  id              String                 @id @default(cuid())
  title           String
  content         String                 @db.Text
  description     String?
  category        String
  tags            String[]
  status          String                 @default("draft") // draft, reviewing, published, archived
  coverUrl        String?
  pdfUrl          String?
  documents       String[] // Array of document URLs (PDF, DOCX, etc.)
  references      String[]
  isCollaborative Boolean                @default(false)
  authorId        String
  author          User                   @relation("ResearchAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  collaborators   ResearchCollaborator[]
  comments        Comment[]
  reactions       Reaction[]
  savedItems      SavedItem[]
  readingProgress ReadingProgress[]
  reposts         Repost[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([authorId])
  @@index([category])
  @@index([status])
}

model ResearchCollaborator {
  id         String   @id @default(cuid())
  researchId String
  research   Research @relation(fields: [researchId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     String   @default("pending") // pending, accepted, rejected
  role       String   @default("collaborator") // collaborator, co-researcher
  invitedBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([researchId, userId])
  @@index([researchId])
  @@index([userId])
  @@index([status])
}

model ArticleCollaborator {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("pending") // pending, accepted, rejected
  role      String   @default("collaborator") // collaborator, co-author
  invitedBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([articleId, userId])
  @@index([articleId])
  @@index([userId])
  @@index([status])
}

model Event {
  id              String              @id @default(cuid())
  title           String
  description     String              @db.Text
  date            DateTime
  time            String?
  location        String
  type            String // Conferencia, Taller, Congreso, etc.
  tags            String[]
  bannerUrl       String?
  isCollaborative Boolean             @default(false)
  archived        Boolean             @default(false)
  creatorId       String
  creator         User                @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  collaborators   EventCollaborator[]
  registrations   EventRegistration[]
  reminders       EventReminder[]
  savedItems      SavedItem[]
  reposts         Repost[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([creatorId])
  @@index([date])
  @@index([type])
  @@index([archived])
}

model EventCollaborator {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("pending") // pending, accepted, rejected
  role      String   @default("collaborator") // collaborator, co-organizer
  invitedBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([status])
}

model BlogPost {
  id         String      @id @default(cuid())
  title      String?
  content    String      @db.Text
  category   String
  tags       String[]
  coverUrl   String? // Cover image for the post
  imageUrl   String? // Additional images in content
  videoUrl   String? // Video URL
  documents  String[] // Array of document URLs (PDF, DOCX, etc.)
  mentions   String[] // Array of user IDs mentioned
  archived   Boolean     @default(false)
  authorId   String
  author     User        @relation("BlogPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reactions  Reaction[]
  comments   Comment[]
  savedItems SavedItem[]
  readingProgress ReadingProgress[]
  reposts    Repost[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([authorId])
  @@index([category])
  @@index([archived])
}

model Discussion {
  id        String    @id @default(cuid())
  title     String
  content   String    @db.Text
  authorId  String
  author    User      @relation("DiscussionAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  comments  Comment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([authorId])
}

model Comment {
  id           String      @id @default(cuid())
  content      String      @db.Text
  authorId     String
  author       User        @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  articleId    String?
  article      Article?    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  researchId   String?
  research     Research?   @relation(fields: [researchId], references: [id], onDelete: Cascade)
  discussionId String?
  discussion   Discussion? @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  postId       String?
  post         BlogPost?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId     String?
  parent       Comment?    @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Comment[]   @relation("CommentReplies")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([authorId])
  @@index([articleId])
  @@index([researchId])
  @@index([discussionId])
  @@index([postId])
  @@index([parentId])
}

model EventRegistration {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
}

model Reaction {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId     String?
  post       BlogPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  articleId  String?
  article    Article?  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  researchId String?
  research   Research? @relation(fields: [researchId], references: [id], onDelete: Cascade)
  type       String // like, clap, heart, etc.
  createdAt  DateTime  @default(now())

  @@unique([userId, postId, type])
  @@unique([userId, articleId, type])
  @@unique([userId, researchId, type])
  @@index([userId])
  @@index([postId])
  @@index([articleId])
  @@index([researchId])
}

model EventReminder {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  reminderType String // "day_before" or "morning_of"
  sent         Boolean  @default(false)
  scheduledFor DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([eventId])
  @@index([scheduledFor])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // comment, reaction, mention, event_reminder, etc.
  title     String
  message   String   @db.Text
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique  // hashed with SHA-256
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique  // hashed with SHA-256
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// Idempotencia: evitar procesar el mismo evento de Stripe dos veces
model StripeEvent {
  id          String   @id        // event.id de Stripe (ej: "evt_xxx")
  type        String              // event.type
  processedAt DateTime @default(now())
}

// Idempotencia: evitar procesar el mismo webhook de MercadoPago dos veces
model MpEvent {
  id          String   @id        // x-request-id de MercadoPago
  processedAt DateTime @default(now())
}

model Repost {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleId  String?
  article    Article?  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  researchId String?
  research   Research? @relation(fields: [researchId], references: [id], onDelete: Cascade)
  postId     String?
  post       BlogPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  eventId    String?
  event      Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@unique([userId, articleId])
  @@unique([userId, researchId])
  @@unique([userId, postId])
  @@unique([userId, eventId])
  @@index([userId])
  @@index([articleId])
  @@index([researchId])
  @@index([postId])
  @@index([eventId])
}
